# Copy this file to .env and fill in your own keys.
# .env is gitignored — never commit real secrets.
#
# Everything here can ALSO be set from inside the app (Settings screen), which
# is the recommended path for day-to-day use. .env is only the first-run
# fallback and is handy for local development / testing.

# Required for real script writing + voiceover + caption/hashtag generation.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Required for real background footage search.
# https://www.pexels.com/api/
PEXELS_API_KEY=

# Optional overrides — sensible defaults are used if omitted.
# Where finished videos are written. Defaults to ./Exports inside the app folder.
DJA_OUTPUT_FOLDER=
# Where your royalty-free background music tracks live. Defaults to ./assets/music.
DJA_MUSIC_FOLDER=
# Path to a logo/watermark PNG (transparent background recommended).
DJA_LOGO_PATH=

# Local dev server port for the Next.js renderer.
PORT=3131
