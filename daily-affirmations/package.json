{
  "name": "dja-daily-affirmations",
  "version": "1.0.0",
  "private": true,
  "description": "DJ&A Digital Studio internal content production system — generates six ready-to-post affirmation videos (Nurse + Autism Parent) every day.",
  "author": "DJ&A Digital Studio Limited",
  "license": "UNLICENSED",
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "next dev -p 3131",
    "build": "next build",
    "start": "next start -p 3131",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "tsx scripts/smoke-test.ts",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:dev": "concurrently -k -n NEXT,ELECTRON -c blue,magenta \"npm:dev\" \"npm:electron:watch\"",
    "electron:watch": "wait-on http://127.0.0.1:3131 && npm run electron:compile && cross-env ELECTRON_DEV=1 electron .",
    "electron:build": "npm run build && npm run electron:compile && electron-builder"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.454.0",
    "next": "^14.2.16",
    "nspell": "^2.1.5",
    "openai": "^4.68.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^1.7.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "write-good": "^1.0.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.16",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "wait-on": "^8.0.1"
  }
}
